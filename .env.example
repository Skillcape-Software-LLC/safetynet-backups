# Optional passphrase for the SSH private key
BACKUP_KEY_PASSPHRASE=

# Host directory that holds the folders you want to back up.
# SafetyNet will discover subfolders here and offer them as sources in the UI —
# you don't need to know the container path, just the folder name.
# Must be an absolute path. ~ does not expand reliably when using sudo.
# Example: /home/youruser/docker
DOCKER_DIR=

# Host directory where local-destination backups are written.
# When you create a "Local" destination in the UI, give it a name and a subfolder
# (e.g. "myserver"). The archive will land at LOCAL_BACKUP_DIR/<subfolder>/ on the host.
# You don't need to think about container paths.
# Must be an absolute path. Create it before starting the containers and ensure it
# is owned by PUID:PGID.
# Example: /mnt/backups
LOCAL_BACKUP_DIR=

# Host directory where restored snapshots are written.
# When you restore an archive in the UI, type a subfolder name (e.g. "myserver");
# the files will be extracted to RESTORE_DIR/<subfolder>/ on the host.
# Must be an absolute path. Create it before starting the containers and ensure it
# is owned by PUID:PGID — Docker will create it as root if it doesn't exist, causing
# permission errors.
#   mkdir -p /home/youruser/restores && chown 1000:1000 /home/youruser/restores
# Example: /home/youruser/restores
RESTORE_DIR=

# Run containers as your host user so mounted directories are readable.
# Find your values with: id -u  and  id -g
PUID=1000
PGID=1000
