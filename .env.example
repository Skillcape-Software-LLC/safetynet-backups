# Optional passphrase for the SSH private key
BACKUP_KEY_PASSPHRASE=

# Optional: absolute path to a custom directory to browse for additional backup sources
# (e.g. your docker project folders). If unset, only the default Docker named volumes
# path (/var/lib/docker/volumes) will be scanned automatically.
# Must be an absolute path — ~ does not expand reliably when using sudo.
# Example: /home/youruser/docker
DOCKER_DIR=

# Directory where restored snapshots will be written (writable).
# Each restore lands in a subdirectory named after the source, e.g. RESTORE_DIR/watchtower.
# Must be an absolute path.
# Example: /home/youruser/docker
RESTORE_DIR=

# Run containers as your host user so mounted directories are readable.
# Find your values with: id -u  and  id -g
PUID=1000
PGID=1000
